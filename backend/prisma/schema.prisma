generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  owner
  manager
  grower
}

enum BayClimateType {
  tropical
  temperate
  arid
  propagation
  shade
  specialty
}

enum BayStatus {
  active
  growing
  sanitizing
  maintenance
  closed
}

enum HarvestStatus {
  recorded
  verified
  disputed
}

enum HarvestType {
  cuttings
  seedlings
  mature
  herbs
  seasonal
  rush
}

enum RepairPriority {
  low
  medium
  high
  urgent
}

enum RepairStatus {
  open
  in_progress
  completed
  cancelled
}

enum IrrigationCategory {
  drip_cycle
  misting
  fertilizer
  pest_scouting
  soil_check
  other
}

enum ScheduleStatus {
  scheduled
  in_progress
  completed
  overdue
}

enum PlantCategory {
  annual_tray
  perennial_pot
  herb_flat
  tree_liner
  bulk_wholesale
  other
}

enum PricingStatus {
  active
  upcoming
  archived
}

enum OrderStatus {
  pending
  in_progress
  completed
  delivered
}

model Nursery {
  id         String   @id @default(uuid())
  name       String
  phone      String?
  address    String?
  city       String?
  state      String?
  zipCode    String?  @map("zip_code")
  totalBays  Int      @default(6) @map("total_bays")
  timezone   String   @default("America/Chicago")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  users               User[]
  greenhouseBays      GreenhouseBay[]
  harvestBatches      HarvestBatch[]
  equipmentRepairs    EquipmentRepair[]
  irrigationSchedules IrrigationSchedule[]
  plantPricing        PlantPricing[]
  plantOrders         PlantOrder[]

  @@map("nurseries")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  firstName    String   @map("first_name")
  lastName     String   @map("last_name")
  role         UserRole @default(owner)
  nurseryId    String   @map("nursery_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  nursery Nursery @relation(fields: [nurseryId], references: [id], onDelete: Cascade)

  @@map("users")
}

model GreenhouseBay {
  id               String          @id @default(uuid())
  nurseryId        String          @map("nursery_id")
  name             String
  zone             String
  climateType      BayClimateType  @default(temperate) @map("climate_type")
  irrigationSystem String?         @map("irrigation_system")
  status           BayStatus       @default(active)
  notes            String?
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  nursery            Nursery            @relation(fields: [nurseryId], references: [id], onDelete: Cascade)
  harvestBatches     HarvestBatch[]
  equipmentRepairs   EquipmentRepair[]

  @@unique([nurseryId, name])
  @@index([nurseryId, status])
  @@map("greenhouse_bays")
}

model HarvestBatch {
  id              String        @id @default(uuid())
  nurseryId       String        @map("nursery_id")
  greenhouseBayId String        @map("greenhouse_bay_id")
  harvestedAt     DateTime      @map("harvested_at")
  harvestType     HarvestType   @default(seedlings) @map("harvest_type")
  cashSales       Float         @default(0) @map("cash_sales")
  cardSales       Float         @default(0) @map("card_sales")
  unitCount       Int           @default(1) @map("unit_count")
  rushPremium     Float         @default(0) @map("rush_premium")
  status          HarvestStatus @default(recorded)
  notes           String?
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  nursery       Nursery       @relation(fields: [nurseryId], references: [id], onDelete: Cascade)
  greenhouseBay GreenhouseBay @relation(fields: [greenhouseBayId], references: [id], onDelete: Cascade)

  @@index([nurseryId, harvestedAt])
  @@index([nurseryId, status])
  @@map("harvest_batches")
}

model EquipmentRepair {
  id              String         @id @default(uuid())
  nurseryId       String         @map("nursery_id")
  greenhouseBayId String         @map("greenhouse_bay_id")
  title           String
  description     String?
  reportedAt      DateTime       @map("reported_at")
  completedAt     DateTime?      @map("completed_at")
  priority        RepairPriority @default(medium)
  status          RepairStatus   @default(open)
  cost            Float?
  notes           String?
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  nursery       Nursery       @relation(fields: [nurseryId], references: [id], onDelete: Cascade)
  greenhouseBay GreenhouseBay @relation(fields: [greenhouseBayId], references: [id], onDelete: Cascade)

  @@index([nurseryId, status])
  @@index([nurseryId, priority])
  @@map("equipment_repairs")
}

model IrrigationSchedule {
  id          String             @id @default(uuid())
  nurseryId   String             @map("nursery_id")
  title       String
  description String?
  category    IrrigationCategory @default(other)
  zone        String?
  scheduledAt DateTime           @map("scheduled_at")
  status      ScheduleStatus     @default(scheduled)
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  nursery Nursery @relation(fields: [nurseryId], references: [id], onDelete: Cascade)

  @@index([nurseryId, scheduledAt])
  @@map("irrigation_schedules")
}

model PlantPricing {
  id              String        @id @default(uuid())
  nurseryId       String        @map("nursery_id")
  title           String
  plantCategory   PlantCategory @default(other) @map("plant_category")
  status          PricingStatus @default(active)
  basePrice       Float         @map("base_price")
  priceMultiplier Float         @default(1.0) @map("price_multiplier")
  notes           String?
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  nursery Nursery @relation(fields: [nurseryId], references: [id], onDelete: Cascade)

  @@index([nurseryId, plantCategory])
  @@map("plant_pricing")
}

model PlantOrder {
  id           String      @id @default(uuid())
  nurseryId    String      @map("nursery_id")
  buyerName    String      @map("buyer_name")
  plantVariety String      @map("plant_variety")
  supplierName String?     @map("supplier_name")
  status       OrderStatus @default(pending)
  price        Float       @default(0)
  notes        String?
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  nursery Nursery @relation(fields: [nurseryId], references: [id], onDelete: Cascade)

  @@index([nurseryId, status])
  @@map("plant_orders")
}
